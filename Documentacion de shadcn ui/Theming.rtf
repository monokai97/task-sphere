  --secondary-foreground: oklch(0.985 0 0);\par
  --muted: oklch(0.269 0 0);\par
  --muted-foreground: oklch(0.708 0 0);\par
  --accent: oklch(0.269 0 0);\par
  --accent-foreground: oklch(0.985 0 0);\par
  --destructive: oklch(0.704 0.191 22.216);\par
  --border: oklch(1 0 0 / 10%);\par
  --input: oklch(1 0 0 / 15%);\par
  --ring: oklch(0.556 0 0);\par
  --chart-1: oklch(0.488 0.243 264.376);\par
  --chart-2: oklch(0.696 0.17 162.48);\par
  --chart-3: oklch(0.769 0.188 70.08);\par
  --chart-4: oklch(0.627 0.265 303.9);\par
  --chart-5: oklch(0.645 0.246 16.439);\par
  --sidebar: oklch(0.205 0 0);\par
