\par
.dark \{\par
  --background: oklch(0.145 0 0);\par
  --foreground: oklch(0.985 0 0);\par
  --card: oklch(0.205 0 0);\par
  --card-foreground: oklch(0.985 0 0);\par
  --popover: oklch(0.205 0 0);\par
  --popover-foreground: oklch(0.985 0 0);\par
