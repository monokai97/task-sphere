  --ring: oklch(0.708 0 0);\par
  --chart-1: oklch(0.646 0.222 41.116);\par
  --chart-2: oklch(0.6 0.118 184.704);\par
  --chart-3: oklch(0.398 0.07 227.392);\par
  --chart-4: oklch(0.828 0.189 84.429);\par
  --chart-5: oklch(0.769 0.188 70.08);\par
  --sidebar: oklch(0.985 0 0);\par
  --sidebar-foreground: oklch(0.145 0 0);\par
  --sidebar-primary: oklch(0.205 0 0);\par
  --sidebar-primary-foreground: oklch(0.985 0 0);\par
  --sidebar-accent: oklch(0.97 0 0);\par
  --sidebar-accent-foreground: oklch(0.205 0 0);\par
