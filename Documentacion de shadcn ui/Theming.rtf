  --sidebar-primary: oklch(0.488 0.243 264.376);\par
  --sidebar-primary-foreground: oklch(0.985 0 0);\par
  --sidebar-accent: oklch(0.269 0 0);\par
  --sidebar-accent-foreground: oklch(0.985 0 0);\par
  --sidebar-border: oklch(1 0 0 / 10%);\par
