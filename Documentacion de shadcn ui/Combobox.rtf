## Usage\par
\par
```tsx showLineNumbers\par
import \{\par
  Combobox,\par
  ComboboxContent,\par
  ComboboxEmpty,\par
  ComboboxInput,\par
  ComboboxItem,\par
  ComboboxList,\par
\} from "@/components/ui/combobox"\par
```\par
\par
```tsx showLineNumbers\par
const frameworks = ["Next.js", "SvelteKit", "Nuxt.js", "Remix", "Astro"]\par
\par
export function ExampleCombobox() \{\par
  return (\par
    <Combobox items=\{frameworks\}>\par
      <ComboboxInput placeholder="Select a framework" />\par
      <ComboboxContent>\par
        <ComboboxEmpty>No items found.</ComboboxEmpty>\par
        <ComboboxList>\par
          \{(item) => (\par
            <ComboboxItem key=\{item\} value=\{item\}>\par
              \{item\}\par
            </ComboboxItem>\par
          )\}\par
        </ComboboxList>\par
      </ComboboxContent>\par
    </Combobox>\par
  )\par
\}\par
```\par
\par
## Composition\par
\par
### Simple\par
\par
A single-line input and a flat list (see [Basic](#basic)).\par
\par
```text\par
Combobox\par
\f1\u9500?\u9472?\u9472?\f0  ComboboxInput\par
\f1\u9492?\u9472?\u9472?\f0  ComboboxContent\par
    \f1\u9500?\u9472?\u9472?\f0  ComboboxEmpty\par
    \f1\u9492?\u9472?\u9472?\f0  ComboboxList\par
        \f1\u9500?\u9472?\u9472?\f0  ComboboxItem\par
        \f1\u9492?\u9472?\u9472?\f0  ComboboxItem\par
```\par
\par
### With chips\par
\par
Multi-select with `multiple`, chips, and a chips input (see [Multiple](#multiple)).\par
\par
```text\par
Combobox\par
\f1\u9500?\u9472?\u9472?\f0  ComboboxChips\par
\f1\u9474?\f0    \f1\u9500?\u9472?\u9472?\f0  ComboboxValue\par
\f1\u9474?\f0    \f1\u9474?\f0    \f1\u9492?\u9472?\u9472?\f0  ComboboxChip\par
\f1\u9474?\f0    \f1\u9492?\u9472?\u9472?\f0  ComboboxChipsInput\par
\f1\u9492?\u9472?\u9472?\f0  ComboboxContent\par
    \f1\u9500?\u9472?\u9472?\f0  ComboboxEmpty\par
    \f1\u9492?\u9472?\u9472?\f0  ComboboxList\par
        \f1\u9500?\u9472?\u9472?\f0  ComboboxItem\par
        \f1\u9492?\u9472?\u9472?\f0  ComboboxItem\par
```\par
\par
### With groups and collection\par
\par
Nested items per group using `ComboboxCollection` inside each `ComboboxGroup`, with a separator between groups (see [Groups](#groups)).\par
\par
```text\par
Combobox\par
\f1\u9500?\u9472?\u9472?\f0  ComboboxInput\par
\f1\u9492?\u9472?\u9472?\f0  ComboboxContent\par
    \f1\u9500?\u9472?\u9472?\f0  ComboboxEmpty\par
    \f1\u9492?\u9472?\u9472?\f0  ComboboxList\par
        \f1\u9500?\u9472?\u9472?\f0  ComboboxGroup\par
        \f1\u9474?\f0    \f1\u9500?\u9472?\u9472?\f0  ComboboxLabel\par
        \f1\u9474?\f0    \f1\u9492?\u9472?\u9472?\f0  ComboboxCollection\par
        \f1\u9474?\f0        \f1\u9500?\u9472?\u9472?\f0  ComboboxItem\par
        \f1\u9474?\f0        \f1\u9492?\u9472?\u9472?\f0  ComboboxItem\par
        \f1\u9500?\u9472?\u9472?\f0  ComboboxSeparator\par
        \f1\u9492?\u9472?\u9472?\f0  ComboboxGroup\par
            \f1\u9500?\u9472?\u9472?\f0  ComboboxLabel\par
            \f1\u9492?\u9472?\u9472?\f0  ComboboxCollection\par
                \f1\u9500?\u9472?\u9472?\f0  ComboboxItem\par
                \f1\u9492?\u9472?\u9472?\f0  ComboboxItem\par
```\par
\par
## Custom Items\par
\par
Use `itemToStringValue` when your items are objects.\par
\par
```tsx showLineNumbers\par
import * as React from "react"\par
\par
import \{\par
  Combobox,\par
  ComboboxContent,\par
  ComboboxEmpty,\par
  ComboboxInput,\par
  ComboboxItem,\par
  ComboboxList,\par
\} from "@/components/ui/combobox"\par
\par
type Framework = \{\par
  label: string\par
  value: string\par
\}\par
\par
const frameworks: Framework[] = [\par
  \{ label: "Next.js", value: "next" \},\par
  \{ label: "SvelteKit", value: "sveltekit" \},\par
  \{ label: "Nuxt", value: "nuxt" \},\par
]\par
\par
export function ExampleComboboxCustomItems() \{\par
  return (\par
    <Combobox\par
      items=\{frameworks\}\par
      itemToStringValue=\{(framework) => framework.label\}\par
    >\par
      <ComboboxInput placeholder="Select a framework" />\par
      <ComboboxContent>\par
        <ComboboxEmpty>No items found.</ComboboxEmpty>\par
        <ComboboxList>\par
          \{(framework) => (\par
            <ComboboxItem key=\{framework.value\} value=\{framework\}>\par
              \{framework.label\}\par
            </ComboboxItem>\par
          )\}\par
        </ComboboxList>\par
      </ComboboxContent>\par
    </Combobox>\par
  )\par
\}\par
```\par
\par
## Multiple Selection\par
\par
Use `multiple` with chips for multi-select behavior.\par
\par
```tsx showLineNumbers\par
import * as React from "react"\par
\par
import \{\par
  Combobox,\par
  ComboboxChip,\par
  ComboboxChips,\par
  ComboboxChipsInput,\par
  ComboboxContent,\par
  ComboboxEmpty,\par
  ComboboxInput,\par
  ComboboxItem,\par
  ComboboxList,\par
  ComboboxValue,\par
\} from "@/components/ui/combobox"\par
\par
const frameworks = ["Next.js", "SvelteKit", "Nuxt.js", "Remix", "Astro"]\par
\par
export function ExampleComboboxMultiple() \{\par
  const [value, setValue] = React.useState<string[]>([])\par
\par
  return (\par
    <Combobox\par
      items=\{frameworks\}\par
      multiple\par
      value=\{value\}\par
      onValueChange=\{setValue\}\par
    >\par
      <ComboboxChips>\par
        <ComboboxValue>\par
          \{value.map((item) => (\par
            <ComboboxChip key=\{item\}>\{item\}</ComboboxChip>\par
          ))\}\par
        </ComboboxValue>\par
        <ComboboxChipsInput placeholder="Add framework" />\par
      </ComboboxChips>\par
      <ComboboxContent>\par
        <ComboboxEmpty>No items found.</ComboboxEmpty>\par
        <ComboboxList>\par
          \{(item) => (\par
            <ComboboxItem key=\{item\} value=\{item\}>\par
              \{item\}\par
            </ComboboxItem>\par
          )\}\par
        </ComboboxList>\par
      </ComboboxContent>\par
    </Combobox>\par
  )\par
\}\par
```\par
