## Usage\par
\par
```tsx showLineNumbers title="app/layout.tsx"\par
import \{ SidebarProvider, SidebarTrigger \} from "@/components/ui/sidebar"\par
import \{ AppSidebar \} from "@/components/app-sidebar"\par
\par
export default function Layout(\{ children \}: \{ children: React.ReactNode \}) \{\par
  return (\par
    <SidebarProvider>\par
      <AppSidebar />\par
      <main>\par
        <SidebarTrigger />\par
        \{children\}\par
      </main>\par
    </SidebarProvider>\par
  )\par
\}\par
```\par
\par
```tsx showLineNumbers title="components/app-sidebar.tsx"\par
import \{\par
  Sidebar,\par
  SidebarContent,\par
  SidebarFooter,\par
  SidebarGroup,\par
  SidebarHeader,\par
\} from "@/components/ui/sidebar"\par
\par
export function AppSidebar() \{\par
  return (\par
    <Sidebar>\par
      <SidebarHeader />\par
      <SidebarContent>\par
        <SidebarGroup />\par
        <SidebarGroup />\par
      </SidebarContent>\par
      <SidebarFooter />\par
    </Sidebar>\par
  )\par
\}\par
```\par
\par
## Composition\par
